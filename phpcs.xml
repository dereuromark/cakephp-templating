<?xml version="1.0"?>
<ruleset name="plugin">
	<arg name="cache" value=".phpcs.cache"/>
    <arg value="nps"/>

    <file>src/</file>
    <file>tests/</file>

    <rule ref="PSR2R"/>

	<rule ref="PhpCollective.PHP.DeclareStrictTypes">
		<properties>
			<property name="declareOnFirstLine" value="yes"/>
		</properties>
	</rule>
</ruleset>
